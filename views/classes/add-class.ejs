<%- include('../includes/head.ejs') %>
<link rel="stylesheet" href="/css/forms.css">
<link rel="stylesheet" href="/css/class.css"> 
</head>
<body>
    <%- include('../includes/navigation.ejs') %>
    <main>
        <form class="class-form" action="/admin/add-class" method="POST">
            <h1>Thêm Lớp học Mới</h1>
            <hr>
            <div class="form-control">
                <label for="name">Tên Lớp học</label>
                <input type="text" name="name" id="name" value="">
            </div>

            <div class="form-control">
                <label for="teacher">Chọn Giáo viên</label>
                <select name="teacherId" id="teacher">
                    <% if (teachers.length > 0) { %>
                        <% teachers.forEach(teacher => { %>
                            <option value="<%= teacher.id %>"><%= teacher.name %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>
            
            <button class="btn" type="submit">Thêm Lớp</button>
        </form>
    </main>
<%- include('../includes/end.ejs') %>