<%- include('../includes/head.ejs') %>
<link rel="stylesheet" href="/css/forms.css">
<link rel="stylesheet" href="/css/table.css">
</head>
<body>
    <%- include('../includes/navigation.ejs') %>

    <main>
        <% if (classInfo) { %>
            <h1>Điểm danh: Lớp <%= classInfo.name %></h1>
            <hr>
            
            <form action="/admin/classes/<%= classInfo.id %>/attendance" method="POST">
                <div class="form-control" style="max-width: 20rem; margin-bottom: 1rem;">
                    <label for="session-number"><b>Chọn buổi học để điểm danh:</b></label>
                    <select name="sessionNumber" id="session-number">
                        <% for(let i = 1; i <= 10; i++) { %>
                            <option value="<%= i %>">Buổi <%= i %></option>
                        <% } %>
                    </select>
                </div>

                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Tên Sinh viên</th>
                            <th>Mã Sinh viên</th>
                            <th>Có mặt? (Tích để điểm danh)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% studentsInClass.forEach(student => { %>
                            <tr>
                                <td><%= student.name %></td>
                                <td><%= student.studentCode %></td>
                                <td style="text-align: center;">
                                    <input 
                                        type="checkbox" 
                                        name="presentStudentIds[]" 
                                        value="<%= student.id %>"
                                    >
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
                <br>
                <button type="submit" class="btn">Lưu kết quả Điểm danh</button>
            </form>
        <% } else { %>
            <h1>Không tìm thấy thông tin lớp học.</h1>
        <% } %>
    </main>

<%- include('../includes/end.ejs') %>