<%- include('../includes/head.ejs') %>
<link rel="stylesheet" href="/css/forms.css">
<link rel="stylesheet" href="/css/class.css"> 
</head>
<body>
    <%- include('../includes/navigation.ejs') %>
    <main>
        <% if (classItem) { %> 
            <form class="class-form" action="/admin/classes/edit" method="POST">
                <h1>Chỉnh sửa thông tin Lớp: <%= classItem.name %></h1>
                <hr>
                <div class="form-control">
                    <label for="name">Tên Lớp học</label>
                    <input type="text" name="name" id="name" value="<%= classItem.name %>">
                </div>

                <div class="form-control">
                    <label for="teacher">Chọn Giáo viên</label>
                    <select name="teacherId" id="teacher">
                        <% if (teachers.length > 0) { %>
                            <% teachers.forEach(teacher => { %>
                                <option 
                                    value="<%= teacher.id %>"
                                    <%= teacher.id === classItem.teacherId ? 'selected' : '' %>
                                >
                                    <%= teacher.name %>
                                </option>
                            <% }) %>
                        <% } %>
                    </select>
                </div>
                
                <input type="hidden" value="<%= classItem.id %>" name="classId">
                <button class="btn" type="submit">Cập nhật Lớp</button>
            </form>
        <% } else { %>
            <h1>Không tìm thấy thông tin lớp học.</h1>
        <% } %>
    </main>
<%- include('../includes/end.ejs') %>